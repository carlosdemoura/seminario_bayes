\begin{frame}{Modelo Semi-Confirmatório}
\begin{itemize}
    \item Divide estações por altitude.
    \item Cidades altas apresentam comportamento extremo.
    \item Variabilidade nas cidades intermediárias sugere fatores latentes adicionais.
    \item Menores amplitudes de HPD nos dados faltantes.
\end{itemize}
\end{frame}

%-------------------------------------------------------
\begin{frame}{Comparativo de desempenho}
\begin{itemize}
    \item Predição de dados faltantes:
    \begin{itemize}
        \item Confirmatório: menor viés relativo.
        \item Semi-confirmatório: menores amplitudes de HPD.
        \item Exploratório: pior desempenho comparativo, mas ainda com métricas altas.
    \end{itemize}
\end{itemize}
\end{frame}

