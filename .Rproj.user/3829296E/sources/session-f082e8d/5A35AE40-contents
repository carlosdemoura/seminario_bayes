\begin{frame}{Descrição dos Modelos Bayesianos}
\small
Baseado em \cite{mayrink2020}, \cite{oliveira2024}:  
\begin{itemize}
    \item Análise fatorial confirmatória e semi-confirmatória.  
    \item Inclusão de estruturas de dependência espacial e temporal.  
    \item Dados: matriz $X$ ($i =$ localidade, $j =$ tempo).  
    \item Modelo: $X_{i,j} \sim N(\alpha_i \lambda_j, \sigma_i^2)$.  
\end{itemize}
\end{frame}

% ---------------------------
\begin{frame}{Análise fatorial exploratória e confirmatória}
\begin{equation*}
X = \alpha \lambda + \epsilon
\end{equation*}

\begin{itemize}
    \item $X$: matriz de observações.  
    \item $\alpha$: cargas (loadings).  
    \item $\lambda$: escores (scores).  
    \item $\epsilon$: ruído $\sim N(0,\sigma^2)$.  
\end{itemize}
\end{frame}


% ---------------------------
\begin{frame}{Identificação e prioris}
\begin{itemize}
    \item Problema: $\alpha \lambda = \alpha Q Q^T \lambda$.  
    \item Solução: prioris informativas.  
\end{itemize}
\pause
\begin{block}{Exemplo de prioris}
\begin{align*}
\alpha &\sim N_n(0, V_\alpha) \\
\lambda &\sim N_m(0, v_\lambda) \\
\sigma^2 &\sim \text{Gama}(a,b)
\end{align*}
\end{block}
\end{frame}

% ---------------------------
\begin{frame}{Análise fatorial semi-confirmatória}
\begin{itemize}
    \item Grupos adicionais $G_e$ (não associados a priori).  
    \item Entradas de $\alpha$ com variâncias altas $\Rightarrow$ modelo aprende associação.  
\end{itemize}

\begin{figure}
\includegraphics[width=0.5\textwidth]{img/cap2_var_alpha_2.png}
\caption{Estrutura semi-confirmatória}
\end{figure}
\end{frame}

% ---------------------------
\begin{frame}{Dependência espacial: modelos CAR}
\scriptsize
\[
Z(A_i) \mid Z(A_{-i}) \sim N\left(\mu_i + \sum_{j} c_{ij}(Z(A_j)-\mu_j), \tau_i^2\right)
\]

\[
\Sigma = \bigl[D(W)-\rho W\bigr]^{-1}
\]

\begin{itemize}
    \item $W$: matriz de vizinhança.  
    \item $\rho$: grau de associação.  
    \item Usado em $\alpha$ para capturar dependência espacial.  
\end{itemize}
\end{frame}

% ---------------------------
\begin{frame}{Dependência temporal nos fatores}
\[
\lambda_{i,\bullet} \sim N_m\left(0, v_\lambda [D(W_\lambda) - \rho_\lambda W_\lambda]^{-1}\right)
\]

\begin{itemize}
    \item Estrutura AR(1) $\approx$ CAR temporal.  
    \item Captura correlação entre tempos consecutivos.  
\end{itemize}
\end{frame}

% ---------------------------
\begin{frame}{Conclusão}
\begin{itemize}
    \item Modelos exploratórios: flexíveis, mas pouco informativos.  
    \item Modelos confirmatórios: exigem conhecimento a priori.  
    \item Modelos semi-confirmatórios: equilíbrio entre flexibilidade e rigidez.  
    \item Dependência espacial (CAR) e temporal (AR(1)/CAR) enriquecem a análise.  
    \item Distribuições posteriores $\Rightarrow$ MCMC.  
\end{itemize}
\end{frame}

