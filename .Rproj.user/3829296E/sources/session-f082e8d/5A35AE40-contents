\begin{frame}{Estudo Modelo Exploratórios}
\begin{itemize}
    \item Um fator, 465 observações, 52 tempos.
    \item Cobertura média: 96\%.
    \item Interpretação:
    \begin{itemize}
        \item Alta cobertura + HPDs curtos = boas estimativas.
        \item $\sigma^2$: entradas com variância maior possuem HPDs mais amplos.
    \end{itemize}
\end{itemize}
\end{frame}

%---------------------------------------
\begin{frame}{Modelo Confirmatório}
\begin{itemize}
    \item Dados agrupados em 5 grupos.
    \item Cobertura média: 97.5\%.
    \item Observações:
    \begin{itemize}
        \item Apenas linhas associadas ao fator apresentam cargas distintas de zero.
        \item Média posterior aproxima bem as cargas reais.
        \item HPDs razoáveis para $\lambda$ e fatores.
    \end{itemize}
\end{itemize}
\end{frame}

%---------------------------------------
\begin{frame}{Modelo Semi-confirmatório}
\begin{itemize}
    \item Dois fatores, 394 observações em 3 grupos.
    \item Cobertura média: 96.4\%.
    \item Grupo extra permite cargas livres de zero.
    \item Interpretação semelhante ao confirmatório, mas com mais flexibilidade nos fatores.
\end{itemize}
\end{frame}

