\begin{frame}{Introdução}
\begin{itemize}
    \item Estudos com dados simulados permitem verificar a qualidade das previsões de modelos estatísticos.
    \item Estratégia:
    \begin{enumerate}[label=(\roman*)]
        \item Escolher valores reais dos parâmetros.
        \item Gerar dados via verossimilhança.
        \item Avaliar se estimativas posteriores aproximam os valores reais.
    \end{enumerate}
    \item Aplicação: modelos exploratório, confirmatório e semi-confirmatório.
    \item Métricas principais:
    \begin{itemize}
        \item Cobertura HPD (\% de intervalos contendo o valor real).
        \item Viés relativo dos estimadores pontuais.
        \item Amplitude média dos intervalos HPD.
    \end{itemize}
\end{itemize}
\end{frame}

%---------------------------------------
\begin{frame}{Esquema de Geração de Dados}
\begin{enumerate}[label=(\roman*)]
    \item Sorteio de 100 coordenadas uniformes no globo.
    \item Atribuição de grupos (modelos confirmatório e semi-confirmatório).
    \item Geração de parâmetros a partir das priors:
    \[
        V_\alpha = 400, \quad V_\lambda = 1, \quad \rho_\alpha = \rho_\lambda = 0.95, \quad a = b = 1
    \]
    \item Valores de $\lambda$ positivos para contornar identificação.
    \item Tesselação de Voronoi para matriz de vizinhança.
    \item Dados simulados via modelo \ref{prior:model}, com $n=100$, $m=30$.
\end{enumerate}
\end{frame}

